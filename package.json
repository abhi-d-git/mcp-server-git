{
  "name": "mcp-server-git",
  "version": "1.0.0",
  "description": "GitHub MCP server — repos, branches, PRs, commits",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "cleanall": "rimraf node_modules dist",
    "cleaninstall": "npm run cleanall && npm install",
    "cleanbuild": "npm run clean && npm run build",
    "cleanstart": "npm run cleanbuild && npm run dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@abhinav-dev/mcp-platform-kit": "^1.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "rimraf": "6.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
